{
  "name": "@diffgazer/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:generated": "node ./scripts/prepare-generated.mjs",
    "predev": "pnpm prepare:generated",
    "dev": "vite dev",
    "prebuild": "pnpm prepare:generated",
    "build": "DOCS_PRERENDER=1 vite build && pnpm run generate:sitemap",
    "build:prerender": "pnpm run build",
    "generate:sitemap": "node --import tsx ./scripts/generate-sitemap.ts",
    "preview": "vite preview --outDir .output/public",
    "pretest": "pnpm prepare:generated",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check src scripts vite.config.ts vite-plugin-docs-rebuild.ts source.config.ts",
    "pretype-check": "pnpm prepare:generated && node ./scripts/generate-route-tree.mjs",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "pretest:e2e": "test -f .output/public/index.html || (echo 'Error: .output/public/index.html not found. Run pnpm build first.' && exit 1)",
    "test:e2e": "env -u NO_COLOR playwright test",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@diffgazer/keys": "workspace:*",
    "@diffgazer/registry": "workspace:*",
    "@diffgazer/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.138.0",
    "@tanstack/router-plugin": "^1.138.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.6.0",
    "fumadocs-mdx": "^14.2.7",
    "lowlight": "^3.3.0",
    "nitro": "^3.0.260429-beta",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "2.3.14",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tanstack/router-generator": "^1.167.9",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/figlet": "^1.7.0",
    "figlet": "^1.10.0",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  }
}
