{
  "name": "@diffgazer/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:generated": "node ./scripts/prepare-generated.mjs",
    "predev": "pnpm prepare:generated",
    "dev": "vite dev",
    "prebuild": "pnpm prepare:generated",
    "build": "DOCS_PRERENDER=1 vite build && pnpm run generate:sitemap",
    "build:prerender": "pnpm run build",
    "generate:sitemap": "node ./scripts/generate-sitemap.mjs",
    "preview": "vite preview --outDir .output/public",
    "pretest": "pnpm prepare:generated",
    "test": "vitest run",
    "test:types": "vitest --typecheck --typecheck.only --run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "pretype-check": "pnpm prepare:generated",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@diffgazer/core": "workspace:*",
    "@diffgazer/keys": "workspace:*",
    "@diffgazer/registry": "workspace:*",
    "@diffgazer/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.138.0",
    "@tanstack/react-start": "^1.138.0",
    "@tanstack/router-plugin": "^1.138.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "figlet": "^1.10.0",
    "fumadocs-core": "^16.6.0",
    "fumadocs-mdx": "^14.2.7",
    "lowlight": "^3.3.0",
    "nitro": "^3.0.260429-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "2.3.14",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/figlet": "^1.7.0",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.0.0"
  }
}
