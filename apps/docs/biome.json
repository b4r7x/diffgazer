{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "extends": "//",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*.js",
      "**/*.jsx",
      "**/*.ts",
      "**/*.tsx",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.json",
      "**/*.jsonc",
      "**/*.md",
      "**/*.mdx",
      "!src/routeTree.gen.ts",
      "!src/index.css",
      "!src/generated",
      "!content/docs/ui",
      "!content/docs/keys",
      "!registry/examples",
      "!public/r/ui",
      "!public/r/keys"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
