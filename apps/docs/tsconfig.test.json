{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node", "vite/client", "@testing-library/jest-dom"],
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "*.test.ts",
    "*.test.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "src/generated/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".source",
    ".output",
    // This config replaces the base excludes, so keep lazy source archives out here too.
    "src/generated/**/*.source.json"
  ]
}
