{
  "extends": "../../libs/core/tsconfig/react.json",
  "include": ["**/*.ts", "**/*.tsx", "src/generated/**/*.json"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "registry/**/*.ts",
    "registry/**/*.tsx",
    // Lazy source archives are runtime artifacts; rooting them exhausts the default tsc heap.
    "src/generated/**/*.source.json"
  ],
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true,
    // Docs only type-checks (noEmit); it never emits declarations, so the base
    // preset's declaration emit is off here. This also avoids declaration
    // namability errors for third-party inferred types we never re-export.
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@/components/ui/select": ["../../libs/ui/dist/components/select.d.ts"],
      "@/*": ["./src/*"],
      "@diffgazer/keys": ["../../libs/keys/src/index.ts"],
      "@diffgazer/registry": ["../../libs/registry/src/index.ts"],
      "@diffgazer/registry/schemas": ["../../libs/registry/src/schemas.ts"],
      "fumadocs-mdx:collections/*": [".source/*"]
    }
  }
}
