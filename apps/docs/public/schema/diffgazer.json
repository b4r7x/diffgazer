{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://r.b4r7.dev/schema/diffgazer.json",
  "title": "Diffgazer Installer Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "aliases": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "components": {
          "type": "string"
        },
        "utils": {
          "type": "string"
        },
        "lib": {
          "type": "string"
        },
        "hooks": {
          "type": "string"
        }
      }
    },
    "componentsFsPath": {
      "type": "string"
    },
    "libFsPath": {
      "type": "string"
    },
    "hooksFsPath": {
      "type": "string"
    },
    "rsc": {
      "type": "boolean"
    },
    "tailwind": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "css": {
          "type": "string"
        }
      },
      "required": [
        "css"
      ]
    },
    "installedComponents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "installedAt": {
            "type": "string"
          },
          "integrationMode": {
            "type": "string",
            "enum": [
              "none",
              "copy",
              "@diffgazer/keys"
            ]
          },
          "keysVersion": {
            "type": "string"
          },
          "installedAs": {
            "type": "string",
            "enum": [
              "explicit",
              "transitive"
            ]
          },
          "cssChunks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "hash": {
                  "type": "string"
                },
                "item": {
                  "type": "string"
                },
                "registryIntegrity": {
                  "type": "string"
                },
                "cliVersion": {
                  "type": "string"
                },
                "integrationMode": {
                  "type": "string",
                  "enum": [
                    "none",
                    "copy",
                    "@diffgazer/keys"
                  ]
                }
              },
              "required": [
                "path",
                "hash",
                "item"
              ]
            }
          }
        },
        "required": [
          "installedAt"
        ]
      }
    }
  }
}
