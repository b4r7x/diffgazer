{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://r.b4r7.dev/schema/diffgazer.json",
  "title": "Diffgazer Installer Config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": {
          "type": "string",
          "pattern": "^(\\.\\.?\\/|[@~#][\\w-]*\\/)"
        },
        "utils": {
          "type": "string",
          "pattern": "^(\\.\\.?\\/|[@~#][\\w-]*\\/)"
        },
        "lib": {
          "type": "string",
          "pattern": "^(\\.\\.?\\/|[@~#][\\w-]*\\/)"
        },
        "hooks": {
          "type": "string",
          "pattern": "^(\\.\\.?\\/|[@~#][\\w-]*\\/)"
        }
      }
    },
    "componentsFsPath": {
      "type": "string"
    },
    "libFsPath": {
      "type": "string"
    },
    "hooksFsPath": {
      "type": "string"
    },
    "rsc": {
      "type": "boolean"
    },
    "tailwind": {
      "type": "object",
      "properties": {
        "css": {
          "type": "string"
        }
      },
      "required": ["css"]
    },
    "installedComponents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "installedAt": {
            "type": "string"
          },
          "integrationMode": {
            "type": "string",
            "enum": ["none", "copy", "@diffgazer/keys"]
          },
          "keysVersion": {
            "type": "string"
          },
          "installedAs": {
            "type": "string",
            "enum": ["explicit", "transitive"]
          },
          "cssChunks": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-f0-9]{16}$"
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "hash": {
                  "type": "string"
                },
                "item": {
                  "type": "string"
                },
                "registryIntegrity": {
                  "type": "string"
                },
                "cliVersion": {
                  "type": "string"
                },
                "integrationMode": {
                  "type": "string",
                  "enum": ["none", "copy", "@diffgazer/keys"]
                },
                "retired": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": ["path", "hash", "item"]
            }
          }
        },
        "required": ["installedAt"]
      }
    }
  }
}
