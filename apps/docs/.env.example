# Common local environment variables for @diffgazer/docs.
# The root .env.example is canonical for the full monorepo env contract.
# Vite inlines VITE_-prefixed values into the client build; the prerender
# server (Nitro/Node) reads them from process.env at runtime.

# Public origin of the docs site, used for SEO canonical/OG URLs and the sitemap.
# Production: https://docs.b4r7.dev
VITE_PUBLIC_ORIGIN=https://docs.b4r7.dev

# Registry origin used by docs artifact sync and registry examples.
# REGISTRY_ORIGIN=https://r.b4r7.dev

# Disable static prerender during local build debugging.
# DOCS_PRERENDER=0

# Skip artifact preparation when workspace artifacts are already prepared.
# DIFFGAZER_SKIP_ARTIFACT_PREPARE=1

# Use workspace artifact sync while developing the docs site.
# DIFFGAZER_DEV=1

# Port for the docs Playwright preview server.
# PLAYWRIGHT_PORT=4173
