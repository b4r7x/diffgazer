# Environment variables read by @diffgazer/landing.
# Vite inlines VITE_-prefixed values into the static client build at build time.

# Origin of the docs site, linked from the landing page "Documentation" link.
# Production: https://docs.b4r7.dev
VITE_DOCS_ORIGIN=https://docs.b4r7.dev

# GitHub repository, linked from the landing page "GitHub" and "MIT License"
# links (the license link appends /blob/main/LICENSE).
# Production: https://github.com/b4r7x/diffgazer
VITE_GITHUB_URL=https://github.com/b4r7x/diffgazer
