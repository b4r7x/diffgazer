{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": ["@changesets/changelog-github", { "repo": "b4r7x/diffgazer" }],
  "commit": false,
  "fixed": [],
  "linked": [["@diffgazer/ui", "@diffgazer/keys"]],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "@diffgazer/core",
    "@diffgazer/registry",
    "@diffgazer/server",
    "@diffgazer/web",
    "@diffgazer/docs",
    "@diffgazer/landing",
    "@diffgazer/hub"
  ],
  "___experimentalUnsafeOptions_WILL_CHANGE_IN_PATCH": {
    "onlyUpdatePeerDependentsWhenOutOfRange": true
  }
}
