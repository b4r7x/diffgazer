{
  "name": "diffgazer-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel dev:web dev:cli",
    "dev:cli": "pnpm --filter diffgazer dev",
    "dev:web": "pnpm --filter @diffgazer/web dev",
    "dev:docs": "pnpm run prepare:docs && pnpm --filter docs dev",
    "prepare:docs": "pnpm --dir ../diff-ui build:artifacts && pnpm --dir ../keyscope build:artifacts && pnpm --filter docs prepare:generated",
    "verify:registry-cleanup": "node ../docs/scripts/verify-registry-cleanup.mjs",
    "build": "node scripts/build-publish-artifacts.mjs && pnpm -r build",
    "build:docs": "pnpm run prepare:docs && pnpm --filter docs build",
    "cli": "pnpm --filter diffgazer dev",
    "web": "pnpm --filter @diffgazer/web dev",
    "docs": "pnpm --filter docs dev",
    "test": "pnpm -r test",
    "build:artifacts": "node scripts/build-publish-artifacts.mjs"
  },
  "dependencies": {
    "@b4r7x/registry-kit": "workspace:*"
  },
  "devDependencies": {
    "diffui-monorepo": "workspace:*",
    "keyscope": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
