{
  "name": "@diffgazer/repo",
  "private": true,
  "version": "0.0.0",
  "description": "Diffgazer monorepo workspace",
  "homepage": "https://github.com/b4r7x/diffgazer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/b4r7x/diffgazer.git"
  },
  "bugs": {
    "url": "https://github.com/b4r7x/diffgazer/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "check": "turbo run check",
    "verify": "pnpm run verify:monorepo && pnpm run validate:artifacts && pnpm run type-check && pnpm run test && pnpm run smoke",
    "verify:monorepo": "node scripts/monorepo/check-invariants.mjs",
    "validate:artifacts": "node scripts/monorepo/validate-artifacts.mjs",
    "smoke": "pnpm run smoke:cli && pnpm run smoke:packages",
    "smoke:cli": "node scripts/monorepo/smoke-cli.mjs",
    "smoke:packages": "node scripts/monorepo/smoke-package-install.mjs",
    "docs:dev": "pnpm --filter @diffgazer/docs dev",
    "docs:prepare": "pnpm --filter @diffgazer/docs prepare:generated",
    "docs:build": "pnpm --filter @diffgazer/docs build",
    "docs:build:prerender": "pnpm --filter @diffgazer/docs build:prerender",
    "docs:preview": "pnpm --filter @diffgazer/docs preview",
    "web:dev": "pnpm --filter @diffgazer/web dev",
    "web:build": "pnpm --filter @diffgazer/web build",
    "web:preview": "pnpm --filter @diffgazer/web preview",
    "diffgazer:dev": "pnpm --filter diffgazer dev",
    "diffgazer:build": "pnpm --filter diffgazer build",
    "diffgazer:start": "pnpm --filter diffgazer start",
    "add:dev": "pnpm --filter @diffgazer/add dev",
    "add:build": "pnpm --filter @diffgazer/add build",
    "add:test": "pnpm --filter @diffgazer/add test",
    "server:dev": "pnpm --filter @diffgazer/server dev",
    "server:start": "pnpm --filter @diffgazer/server start",
    "ui:test": "pnpm --filter @diffgazer/ui test",
    "keys:playground": "pnpm --dir libs/keys/examples/playground dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@chialab/vitest-axe": "^0.19.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "vitest": "^4.1.0"
  },
  "type": "module"
}
