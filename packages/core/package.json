{
  "name": "@diffgazer/core",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js"
    },
    "./strings": {
      "types": "./dist/strings.d.ts",
      "import": "./dist/strings.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.js"
    },
    "./providers": {
      "types": "./dist/providers/display-status.d.ts",
      "import": "./dist/providers/display-status.js"
    },
    "./review": {
      "types": "./dist/review/index.d.ts",
      "import": "./dist/review/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js"
    },
    "./get-figlet": {
      "types": "./dist/get-figlet.d.ts",
      "import": "./dist/get-figlet.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@diffgazer/schemas": "workspace:*",
    "figlet": "^1.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@diffgazer/tsconfig": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  }
}
