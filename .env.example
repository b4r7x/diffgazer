# Origins (Docker build args; baked into client bundles at build time)

# Registry origin for shadcn CLI and dgadd
REGISTRY_ORIGIN=https://r.b4r7.dev

# Registry origin exposed to Vite client code (docs consumption-metadata)
VITE_REGISTRY_ORIGIN=https://r.b4r7.dev

# Public origin for docs site (SEO, sitemap, canonical URLs)
VITE_PUBLIC_ORIGIN=https://docs.b4r7.dev

# AI provider credentials (web/CLI review)
# At least one is required to run a review. The provider you pick determines
# which variable is read (see PROVIDER_ENV_VARS in libs/core).
# GOOGLE_API_KEY=        # gemini
# ZAI_API_KEY=           # zai, zai-coding
# OPENROUTER_API_KEY=    # openrouter

# API server

# Port for the diffgazer API server and docker-compose port mapping.
# Keep this in sync with the host/port in VITE_API_URL below.
PORT=3000

# Shutdown token for the embedded packaged SPA. Injected automatically in
# packaged mode (set by the CLI); leave unset for local development.
# VITE_DIFFGAZER_SHUTDOWN_TOKEN=

# Web app

# API URL for the web app dev proxy and runtime fetch. Recommended for local
# development; defaults to http://127.0.0.1:3000 when unset.
VITE_API_URL=http://127.0.0.1:3000

# Development and build flags

# Switch artifact sync to development mode (local workspace artifacts).
# DIFFGAZER_DEV=1

# Skip the artifact-prepare prelude in root scripts and turbo tasks.
# DIFFGAZER_SKIP_ARTIFACT_PREPARE=1

# Dev-only: trust the project-root request header in the server. Ignored in
# packaged mode. Do not enable outside local development.
# DIFFGAZER_DEV_UNSAFE_PROJECT_ROOT=1

# Port for the docs Playwright preview server (defaults to 4173).
# PLAYWRIGHT_PORT=4173

# Enable docs static prerender during the docs build.
# DOCS_PRERENDER=1

# Deployment (GitHub Actions secrets)

# Coolify deploy webhook used by the deploy workflow.
# COOLIFY_WEBHOOK_URL=https://your-coolify-instance/api/v1/deploy
# COOLIFY_TOKEN=your-coolify-api-token
