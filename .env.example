# Origins (Docker build args; baked into client bundles at build time)

# Registry origin for shadcn CLI and dgadd
REGISTRY_ORIGIN=https://r.b4r7.dev

# Public origin for docs site (SEO, sitemap, canonical URLs)
VITE_PUBLIC_ORIGIN=https://docs.b4r7.dev

# AI provider credentials (web/CLI review)
# At least one is required to run a review. The provider you pick determines
# which variable is read (see PROVIDER_ENV_VARS in libs/core).
# GOOGLE_API_KEY=        # gemini
# ZAI_API_KEY=           # zai, zai-coding
# OPENROUTER_API_KEY=    # openrouter
# GROQ_API_KEY=          # groq
# CEREBRAS_API_KEY=      # cerebras

# User-set API server and runtime overrides

# Port for the diffgazer API server.
# Keep this in sync with the host/port in VITE_API_URL below.
PORT=3000

# Move config.json, secrets.json, and trust.json under a custom home directory.
# DIFFGAZER_HOME=~/.diffgazer

# Project root reviewed by the server. The packaged CLI sets this automatically;
# set it only when running the server outside the CLI.
# DIFFGAZER_PROJECT_ROOT=/path/to/repo

# Server log level: debug, info, warn, or error.
# DIFFGAZER_LOG_LEVEL=info

# Use the bundled model catalog snapshot instead of fetching models.dev.
# DIFFGAZER_OFFLINE=1

# Delay before the CLI force-kills a child process after SIGTERM.
# DIFFGAZER_FORCE_KILL_DELAY_MS=2000

# CLI-injected variables

# These are set automatically in packaged mode. Leave them unset by hand.
# In packaged mode the API token gate is always on. In split dev (not packaged,
# no token set) the gate is disabled, so any localhost origin can reach /api/*
# routes — acceptable in dev only. Set DIFFGAZER_SHUTDOWN_TOKEN to require the
# token even in split dev; the server logs a warning at startup when the gate is
# off. See SECURITY.md.
# DIFFGAZER_SHUTDOWN_TOKEN=
# VITE_DIFFGAZER_SHUTDOWN_TOKEN=
# DIFFGAZER_CLI_PID=
# DIFFGAZER_PACKAGED=1

# Web app

# API URL for the web app dev proxy and runtime fetch. Recommended for local
# development; defaults to http://127.0.0.1:3000 when unset.
VITE_API_URL=http://127.0.0.1:3000

# Development and build flags

# Switch artifact sync to development mode (local workspace artifacts).
# DIFFGAZER_DEV=1

# Skip the artifact-prepare prelude in root scripts and turbo tasks.
# DIFFGAZER_SKIP_ARTIFACT_PREPARE=1

# Dev-only: trust the project-root request header in the server. Ignored in
# packaged mode. Do not enable outside local development.
# DIFFGAZER_DEV_UNSAFE_PROJECT_ROOT=1

# Port for the docs Playwright preview server (defaults to 4173).
# PLAYWRIGHT_PORT=4173

# Docs static prerender is on by default during the docs build; set to 0 to disable.
# DOCS_PRERENDER=0

# Deployment (GitHub production environment secrets)

# Coolify deploy token and one webhook per Docker Image resource.
# COOLIFY_TOKEN=your-coolify-api-token
# COOLIFY_WEBHOOK_DOCS=https://your-coolify-instance/api/v1/deploy/docs
# COOLIFY_WEBHOOK_REGISTRY=https://your-coolify-instance/api/v1/deploy/registry
# COOLIFY_WEBHOOK_LANDING=https://your-coolify-instance/api/v1/deploy/landing
