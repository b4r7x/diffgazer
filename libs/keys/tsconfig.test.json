{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@diffgazer/keys": ["./src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "registry/**/*.ts",
    "registry/**/*.tsx",
    "scripts/**/*.test.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
