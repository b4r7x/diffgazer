{
  "name": "@diffgazer/keys",
  "version": "0.2.0",
  "description": "Composable, scoped keyboard navigation hooks for React",
  "license": "MIT",
  "author": "diffgazer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/b4r7x/diffgazer.git",
    "directory": "libs/keys"
  },
  "homepage": "https://github.com/b4r7x/diffgazer/tree/main/libs/keys",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./navigation": {
      "types": "./dist/hooks/use-navigation.d.ts",
      "import": "./dist/hooks/use-navigation.js"
    },
    "./focus-restore": {
      "types": "./dist/hooks/use-focus-restore.d.ts",
      "import": "./dist/hooks/use-focus-restore.js"
    },
    "./focus-trap": {
      "types": "./dist/hooks/use-focus-trap.d.ts",
      "import": "./dist/hooks/use-focus-trap.js"
    },
    "./scroll-lock": {
      "types": "./dist/hooks/use-scroll-lock.d.ts",
      "import": "./dist/hooks/use-scroll-lock.js"
    },
    "./focusable": {
      "types": "./dist/dom/focusable.d.ts",
      "import": "./dist/dom/focusable.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "navigation": ["./dist/hooks/use-navigation.d.ts"],
      "focus-restore": ["./dist/hooks/use-focus-restore.d.ts"],
      "focus-trap": ["./dist/hooks/use-focus-trap.d.ts"],
      "scroll-lock": ["./dist/hooks/use-scroll-lock.d.ts"],
      "focusable": ["./dist/dom/focusable.d.ts"]
    }
  },
  "files": [
    "dist",
    "!dist/artifacts",
    "!dist/artifacts/**",
    "internal-docs-manifest.json",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/b4r7x/diffgazer/issues"
  },
  "scripts": {
    "build": "pnpm validate:registry && rm -rf dist && tsc && pnpm verify:dist-esm && pnpm verify:rsc && pnpm build:shadcn && pnpm build:artifacts",
    "build:shadcn": "node --import tsx scripts/build-shadcn-registry.ts",
    "build:artifacts": "pnpm build:docs-data && node --import tsx scripts/build-publish-artifacts.ts",
    "build:docs-data": "node --import tsx scripts/build-docs-data.ts",
    "validate:registry": "node --import tsx scripts/validate-registry-closure.ts",
    "verify:rsc": "node --import tsx scripts/verify-rsc-directives.ts",
    "verify:dist-esm": "node --import tsx scripts/verify-dist-esm-imports.ts",
    "validate:artifacts": "pnpm --dir ../.. validate:artifacts",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck --typecheck.only --run",
    "verify:registry-cleanup": "node ../../apps/docs/scripts/verify-registry-cleanup.mjs --scope @diffgazer/keys",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm run test && pnpm run validate:artifacts",
    "playground": "pnpm --filter playground dev"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@diffgazer/registry": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.0",
    "jsdom": "^28.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.7.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "react",
    "keyboard",
    "hotkeys",
    "shortcuts",
    "navigation",
    "focus",
    "accessibility",
    "a11y",
    "scoped",
    "zones"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
