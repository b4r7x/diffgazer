  "scripts": {
    "build": "tsc && pnpm verify:dist-esm",
    "verify:dist-esm": "node --import tsx scripts/verify-dist-esm-imports.ts",
    "generate:catalog-snapshot": "node --import tsx scripts/generate-catalog-snapshot.ts",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p scripts/tsconfig.json",
    "check": "biome check .",
    "test": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:watch": "vitest"
