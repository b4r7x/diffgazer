{
  "name": "@diffgazer/ui",
  "version": "0.1.0",
  "description": "Terminal-inspired React UI component library",
  "homepage": "https://github.com/b4r7x/diffgazer/tree/main/libs/ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/b4r7x/diffgazer.git",
    "directory": "libs/ui"
  },
  "bugs": {
    "url": "https://github.com/b4r7x/diffgazer/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./components/*": {
      "import": {
        "types": "./dist/components/*.d.ts",
        "default": "./dist/components/*.js"
      }
    },
    "./hooks/*": {
      "import": {
        "types": "./dist/hooks/*.d.ts",
        "default": "./dist/hooks/*.js"
      }
    },
    "./lib/*": {
      "import": {
        "types": "./dist/lib/*.d.ts",
        "default": "./dist/lib/*.js"
      }
    },
    "./theme-base.css": "./dist/theme-base.css",
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && pnpm build:shadcn && pnpm build:artifacts",
    "build:shadcn": "node --import tsx scripts/build-shadcn-registry.ts",
    "build:artifacts": "node --import tsx scripts/build-publish-artifacts.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "figlet": "^1.10.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "@diffgazer/keys": ">=0.1.0",
    "lucide-react": ">=0.400.0"
  },
  "peerDependenciesMeta": {
    "@diffgazer/keys": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@diffgazer/keys": "workspace:*",
    "@diffgazer/registry": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "shadcn": "^2.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
