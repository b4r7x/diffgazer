    "!dist/components/dialog-shell.js",
    "!dist/components/dialog-shell.d.ts",
    "!dist/components/portal.js",
    "!dist/components/portal.d.ts",
    "!dist/_types/registry/ui/shared",
    "!dist/_types/registry/ui/shared/**",
    "!dist/_types/shared",
    "!dist/_types/shared/**",
    "!dist/artifacts",
    "!dist/artifacts/**",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "Chrome >= 111",
    "Safari >= 16.4",
    "Firefox >= 128",
    "Edge >= 111",
    "last 2 Chrome versions",
    "last 2 Safari versions",
    "last 2 Firefox versions"
  ],
  "scripts": {
    "build": "pnpm validate:registry && tsup && pnpm build:declarations && pnpm build:shadcn && pnpm build:docs-data && pnpm build:artifacts",
    "build:declarations": "node --import tsx scripts/build-declarations.ts",
    "build:shadcn": "node --import tsx scripts/build-shadcn-registry.ts",
    "build:docs-data": "node --import tsx scripts/build-docs-data.ts",
    "build:artifacts": "node --import tsx scripts/build-publish-artifacts.ts",
    "validate:registry": "node --import tsx scripts/validate-registry-metadata.ts",
    "validate:artifacts": "pnpm --dir ../.. validate:artifacts",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.tools.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck --typecheck.only --run",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm run test && pnpm run validate:artifacts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@diffgazer/keys": ">=0.1.1",
    "figlet": ">=1.10.0",
    "lowlight": ">=3.0.0",
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0"
  },
  "peerDependenciesMeta": {
    "figlet": {
      "optional": true
    },
    "lowlight": {
      "optional": true
    }
  },
  "devDependencies": {
    "@diffgazer/keys": "workspace:*",
    "@diffgazer/registry": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/hast": "^3.0.4",
    "@types/jsdom": "^28.0.3",
    "lowlight": "^3.3.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "esbuild": "^0.27.0",
    "shadcn": "^4.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
