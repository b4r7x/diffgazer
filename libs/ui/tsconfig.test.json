{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "registry/**/*.ts",
    "registry/**/*.tsx",
    "shared/**/*.ts",
    "testing/**/*.ts",
    "theme/**/*.ts",
    "scripts/**/*.test.ts",
    "src/test-setup.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
