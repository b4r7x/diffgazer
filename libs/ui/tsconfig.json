{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["registry/lib/*"],
      "@/hooks/*": ["registry/hooks/*"],
      "@/components/ui/*": ["registry/ui/*"]
    }
  },
  "include": [
    "registry/**/*.ts",
    "registry/**/*.tsx",
    "shared/**/*.ts"
  ],
  "exclude": [
    "registry/**/*.test.ts",
    "registry/**/*.test.tsx",
    "registry/**/testing/**",
    "registry/component-docs/**",
    "registry/hook-docs/**",
    "registry/examples/**"
  ]
}
