{
  "extends": "../tsconfig.json",
  "references": [{ "path": "../tsconfig.test.json" }],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/ui/*": ["./ui/*"],
      "@/lib/*": ["./lib/*"],
      "@/hooks/*": ["./hooks/*"]
    }
  },
  "include": [
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "lib/**/*.ts",
    "component-docs/**/*.ts",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
