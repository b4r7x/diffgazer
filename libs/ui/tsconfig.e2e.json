{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "playwright.config.ts",
    "vite.e2e.config.ts",
    "testing/e2e/**/*.ts",
    "testing/fixtures/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
