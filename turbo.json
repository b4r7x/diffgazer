{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["DIFFGAZER_SKIP_ARTIFACT_PREPARE", "DIFFGAZER_ARTIFACT_SYNC_MODE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/docs#build": {
      "dependsOn": ["^build"],
      "env": [
        "REGISTRY_ORIGIN",
        "VITE_PUBLIC_ORIGIN",
        "DOCS_PRERENDER",
        "DIFFGAZER_DEV",
        "DIFFGAZER_ARTIFACT_SYNC_MODE"
      ],
      "outputs": ["dist/**", ".output/**"]
    },
    "@diffgazer/landing#build": {
      "dependsOn": ["^build"],
      "env": ["VITE_DOCS_ORIGIN"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/web#build": {
      "dependsOn": ["^build"],
      "env": ["VITE_API_URL", "VITE_DIFFGAZER_SHUTDOWN_TOKEN"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/add#build": {
      "dependsOn": ["^build", "generate:bundles"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/ui#build": {
      "dependsOn": ["^build"],
      "env": ["REGISTRY_ORIGIN"],
      "outputs": ["dist/**", "public/r/**", "docs/generated/**"]
    },
    "@diffgazer/keys#build": {
      "dependsOn": ["^build"],
      "env": ["REGISTRY_ORIGIN"],
      "outputs": ["dist/**", "public/r/**", "docs/generated/**", "artifacts/artifacts/**"]
    },
    "type-check": {
      "dependsOn": ["^build", "^type-check"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@diffgazer/add#test": {
      "dependsOn": ["^build", "generate:bundles"]
    },
    "generate:bundles": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/**"]
    },
    "test:types": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"]
    }
  }
}
