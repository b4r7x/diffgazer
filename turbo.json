{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["DIFFGAZER_SKIP_ARTIFACT_PREPARE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/docs#build": {
      "dependsOn": ["^build"],
      "env": ["REGISTRY_ORIGIN", "VITE_REGISTRY_ORIGIN", "VITE_PUBLIC_ORIGIN", "DOCS_PRERENDER", "DIFFGAZER_DEV"],
      "outputs": ["dist/**", ".output/**"]
    },
    "@diffgazer/landing#build": {
      "dependsOn": ["^build"],
      "env": ["VITE_DOCS_ORIGIN"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/web#build": {
      "dependsOn": ["^build"],
      "env": ["VITE_API_URL", "VITE_DIFFGAZER_SHUTDOWN_TOKEN"],
      "outputs": ["dist/**"]
    },
    "diffgazer#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "dependsOn": ["^test", "^build"]
    },
    "@diffgazer/add#test": {
      "dependsOn": ["^build", "generate:bundles"]
    },
    "generate:bundles": {
      "outputs": ["src/generated/**"]
    },
    "test:types": {
      "dependsOn": ["^build", "^test:types"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"]
    }
  }
}
