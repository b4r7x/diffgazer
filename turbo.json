{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["DIFFGAZER_SKIP_ARTIFACT_PREPARE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@diffgazer/docs#build": {
      "dependsOn": ["^build"],
      "env": ["REGISTRY_ORIGIN", "VITE_PUBLIC_ORIGIN", "DOCS_PRERENDER", "DIFFGAZER_DEV"],
      "outputs": ["dist/**", ".output/**"]
    },
    "@diffgazer/landing#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "diffgazer#build": {
      "dependsOn": ["^build", "@diffgazer/web#build"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "test:types": {
      "dependsOn": ["^build", "^test:types"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "prepare:generated": {
      "cache": false
    }
  }
}
