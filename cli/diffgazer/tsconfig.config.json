{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../libs/core/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node"]
  },
  "include": ["tsup.config.ts", "vitest.config.ts"]
}
