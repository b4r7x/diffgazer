{
  "name": "diffgazer",
  "version": "0.1.4",
  "description": "Local AI code review — embedded web UI and TUI",
  "keywords": [
    "ai",
    "code-review",
    "cli",
    "diff",
    "git",
    "terminal",
    "tui",
    "diffgazer",
    "review",
    "local"
  ],
  "license": "Apache-2.0",
  "author": "diffgazer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/b4r7x/diffgazer.git",
    "directory": "cli/diffgazer"
  },
  "homepage": "https://github.com/b4r7x/diffgazer/tree/main/cli/diffgazer",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/b4r7x/diffgazer/issues"
  },
  "type": "module",
  "bin": {
    "diffgazer": "bin/diffgazer.js"
  },
  "files": [
    "dist",
    "bin/diffgazer.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run build:deps && pnpm run clean && pnpm build:web && pnpm build:bundle && pnpm build:notices",
    "build:deps": "pnpm --dir=../.. turbo run build --filter=@diffgazer/core --filter=@diffgazer/server --filter=@diffgazer/keys --filter=@diffgazer/ui --filter=@diffgazer/web",
    "build:web": "pnpm --filter @diffgazer/web exec tsc -b && pnpm --filter @diffgazer/web exec vite build --outDir ../../cli/diffgazer/dist/web",
    "build:bundle": "tsup",
    "build:notices": "node --import tsx scripts/generate-third-party-notices.ts",
    "prepack": "pnpm run build",
    "dev": "tsx --tsconfig tsconfig.json src/index.tsx --dev",
    "type-check": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "check": "biome check .",
    "test": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:watch": "vitest",
    "start": "node bin/diffgazer.js",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm run test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@inkjs/ui": "^2.0.0",
    "execa": "^9.6.1",
    "figlet": "^1.10.0",
    "hono": "^4.12.18",
    "ink": "^7",
    "ink-spinner": "^5.0.0",
    "open": "^11.0.0",
    "@tanstack/react-query": "^5.80.7",
    "react": "^19.2.4"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.2.0"
  },
  "devDependencies": {
    "@diffgazer/core": "workspace:*",
    "@diffgazer/keys": "workspace:*",
    "@diffgazer/server": "workspace:*",
    "@diffgazer/web": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.13",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
